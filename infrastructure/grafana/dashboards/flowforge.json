{
  "title": "FlowForge Overview",
  "uid": "flowforge-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Active Workflow Runs",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(flowforge_active_runs)",
          "legendFormat": "Active"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 50 }] } } }
    },
    {
      "id": 2,
      "title": "Workflow Runs Total",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(increase(flowforge_workflow_runs_total[1h]))",
          "legendFormat": "Last 1h"
        }
      ],
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 3,
      "title": "Run Outcomes (last 1h)",
      "type": "piechart",
      "gridPos": { "x": 8, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by(status) (increase(flowforge_workflow_run_outcomes_total[1h]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "HTTP Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by(service) (rate(flowforge_http_requests_total[1m]))",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "HTTP P99 Latency (s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by(service, le) (rate(flowforge_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 {{service}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Node Executions by Type (last 1h)",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 5 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by(node_type) (increase(flowforge_node_executions_total[1h]))",
          "legendFormat": "{{node_type}}"
        }
      ],
      "options": { "orientation": "horizontal" }
    },
    {
      "id": 7,
      "title": "Node Execution Failures (last 1h)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 10, "w": 4, "h": 5 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(increase(flowforge_node_executions_total{status=\"FAILED\"}[1h]))",
          "legendFormat": "Failures"
        }
      ],
      "options": { "colorMode": "background" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 1 }] } } }
    },
    {
      "id": 8,
      "title": "Node P95 Execution Duration (s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 15, "w": 24, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by(node_type, le) (rate(flowforge_node_execution_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{node_type}}"
        }
      ]
    }
  ]
}
